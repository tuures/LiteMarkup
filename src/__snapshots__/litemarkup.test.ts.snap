exports[`markdown compatibility mode 2`] = `
"<p><span style="font-weight: bold;">I'm bold</span>
<span style="font-weight: bold;">I'm bold too</span></p>
<p><span style="font-style: italic;">I'm italic</span>
<span style="font-style: italic;">I'm italic too</span></p>
<p>these are supported:
<span style="font-weight: bold;">bold outside and <span style="font-style: italic;">italic inside</span></span>
<span style="font-weight: bold;">bold outside and <span style="font-style: italic;">italic inside</span></span>
<span style="font-style: italic;">italic outside and <span style="font-weight: bold;">bold inside</span></span>
<span style="font-style: italic;">italic outside and <span style="font-weight: bold;">bold inside</span></span></p>
<p>these are not supported:
<span style="font-weight: bold;">bold outside and *italic inside</span><span style="font-style: italic;">
<span style="font-weight: bold;">bold outside and _italic inside</span><span style="font-style: italic;">
</span>italic outside and <span style="font-weight: bold;">bold inside</span>_
</span>italic outside and <span style="font-weight: bold;">bold inside</span>*</p>
<p>_not italic</p>
<p>not italic_</p>
<p>a<span style="font-weight: bold;">bold</span></p>
<p><span style="font-style: italic;">italic</span>s</p>
<p>*not emphasized*</p>
<p><span style="font-style: italic;">emphasized star*</span></p>
<p><span style="font-style: italic;">_italic underlines_</span></p>
<p><span style="font-style: italic;">italic underline_and star*</span></p>
<p>\\<span style="font-style: italic;">emphasis after a literal backslash</span></p>
<p>*just plain p before code<code>*</code></p>"
`;

