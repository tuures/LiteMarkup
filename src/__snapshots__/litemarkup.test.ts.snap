exports[`basic 2`] = `
"<h3>foo😀</h3>
<hr/>
<p>this will be &lt;b&gt;just text not html&lt;/b&gt; and&amp;amp will be escaped in output;</p>
<p>text followed immediately by a</p>
<h1>heading</h1>
<p>This is a list:</p>
<ul>
  <li>
    <p>one</p>
  </li>
  <li>
    <p>two</p>
  </li>
  <li>
    <p>three</p>
  </li>
  <li>
    <p>fourth item</p>
    <p>Another paragraph inside the fourth item</p>
  </li>
  <li>
    <p>fifth</p>
  </li>
</ul>
<ol start="1">
  <li>
    <p>first</p>
  </li>
  <li>
    <p>second</p>
  </li>
  <li>
    <p>third</p>
  </li>
</ol>
<p>just a paragraph</p>
<pre><code data-infotext="clara">foo = bar
 bar = zot
 1 &lt; 2
</code></pre>
<p>immediate code:</p>
<pre><code>  foo = bar
</code></pre>
<pre><code></code></pre>
<pre><code data-infotext="justnewline&quot;&gt;eviltext">
</code></pre>
<p>text not part of quote</p>
<blockquote>
  <p>quote here</p>
</blockquote>
<p>text and empty quote</p>
<blockquote></blockquote>
<blockquote>
  <h1>heading in quote</h1>
  <p>something &lt;nottag&gt;</p>
</blockquote>
<p>Every line in a blockquote must be prefixed with a &gt;, even the empty ones. This lines breaks the quote into two.</p>
<blockquote>
  <p>another quote</p>
</blockquote>
<blockquote>
  <p>level 1</p>
  <blockquote>
    <p>level 2
    level 2</p>
  </blockquote>
  <p>level 1 continues</p>
</blockquote>
<div>
embedded raw html, not escaped
and can contain multiple lines
both opening and closing tags must be on their own lines
<div>
closing tag must be followed by empty line or end of file
</div>
</div>
<p>abc <code>codespan content</code> bar</p>
<p><code>codespan made with 2 backticks</code></p>
<p><code>codespan that has \` backtick inside</code></p>
<p>h\`i<br/>xfoobar</p>
<p>xyz\`xyz<br/>yfoobar</p>
<p>br in the end <br/></p>
<p><b>I'm bold</b></p>
<p><i>I'm italic</i></p>
<p><b>bold outside and <i>italic inside</i></b></p>
<p>_not italic start</p>
<p>not italic ending_</p>
<p><i>italic with _space closes at the end</i></p>
<p>_not italic _as closing missing</p>
<p><i>italic underscore _</i></p>
<p><i>italic underscore and non-italic underscore _</i>_</p>
<p><i>italic underscore and 2x non-italic underscore _</i>__</p>
<p>empty content is not valid italic __</p>
<p>aftert this comes a few paragraphs with just one character</p>
<p>a</p>
<p>#</p>
<p>_</p>
<p>aftert this comes a text content that is just one characters</p>
<p>a<b>bold</b></p>
<p><i>italic</i>s</p>
<p><del>deleted</del></p>
<p><i>*mixed order, first marker (in this case italic) wins</i>*</p>
<p>!&quot;#$%&amp;'()*+,-./:;&lt;=&gt;?@[\\]^_\`{|}~</p>
<p>\\→\\A\\a\\ \\3\\φ\\«</p>
<p>*not emphasized*</p>
<p><b>emphasized star*</b></p>
<p>_not italic_</p>
<p>*not bold*</p>
<p><i>_italic underlines_</i></p>
<p><i>italic underline_and star*</i></p>
<p>\\<b>emphasis</b></p>
<p>*not bold as codespan has priority<code>*</code></p>
<p>this paragraph has a <a href="/thisurl">link to</a> and <a href="/thisurl">another link to</a></p>
<p>not a link as url is missing []&lt;&gt; []()</p>
<p>not an image as url is missing ![]() ![]&lt;&gt;</p>
<p><a href="/link-without-body"></a></p>
<p>[<a href="ds\\)fd\\)\\\`">foo]a</a></p>
<p><a href="url">brackets [] and quotes &quot;&quot; inside link body</a></p>
<p><img alt="image of a cat" src="/ordidnthappen.jpg"/></p>
<p><img alt="" src="/without-alt.jpg"/></p>
<p><img alt="another image of a &quot;cat&quot;[]" src="/ordidnthappen.jpg"/></p>
<p><a href="url">link with <img alt="image of a cat" src="/"/> inside link body</a></p>
