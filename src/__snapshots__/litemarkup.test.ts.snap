exports[`spaces inside codespans 1`] = `
[
  {
    "body": [
      {
        "name": "",
        "txt": "a ",
      },
      {
        "name": "cs",
        "txt": " ",
      },
      {
        "name": "",
        "txt": "1 space is preserved alone",
      },
    ],
    "name": "p",
  },
  {
    "body": [
      {
        "name": "",
        "txt": "b ",
      },
      {
        "name": "cs",
        "txt": "  ",
      },
      {
        "name": "",
        "txt": "2 spaces is preserved alone",
      },
    ],
    "name": "p",
  },
  {
    "body": [
      {
        "name": "",
        "txt": "c ",
      },
      {
        "name": "cs",
        "txt": "   ",
      },
      {
        "name": "",
        "txt": "3 spaces is preserved alone",
      },
    ],
    "name": "p",
  },
  {
    "body": [
      {
        "name": "",
        "txt": "e ",
      },
      {
        "name": "cs",
        "txt": "y",
      },
      {
        "name": "",
        "txt": " first and last spaces are trimmed away when there's more than just spaces",
      },
    ],
    "name": "p",
  },
  {
    "body": [
      {
        "name": "",
        "txt": "f ",
      },
      {
        "name": "cs",
        "txt": "z ",
      },
      {
        "name": "",
        "txt": " first and last spaces are trimmed away, but the one after z is preserved",
      },
    ],
    "name": "p",
  },
  {
    "body": [
      {
        "name": "",
        "txt": "g ",
      },
      {
        "name": "cs",
        "txt": "\`",
      },
      {
        "name": "",
        "txt": " codespan that results in a single backtick (first and last space trmmed away)",
      },
    ],
    "name": "p",
  },
  {
    "body": [
      {
        "name": "",
        "txt": "h ",
      },
      {
        "name": "cs",
        "txt": "\` x \`",
      },
      {
        "name": "",
        "txt": "3 codespan that results in backtick, space, x, space, and backtick",
      },
    ],
    "name": "p",
  },
]
`;

exports[`spaces inside codespans 2`] = `
"<p>a <code> </code>1 space is preserved alone</p>
<p>b <code>  </code>2 spaces is preserved alone</p>
<p>c <code>   </code>3 spaces is preserved alone</p>
<p>e <code>y</code> first and last spaces are trimmed away when there's more than just spaces</p>
<p>f <code>z </code> first and last spaces are trimmed away, but the one after z is preserved</p>
<p>g <code>\`</code> codespan that results in a single backtick (first and last space trmmed away)</p>
<p>h <code>\` x \`</code>3 codespan that results in backtick, space, x, space, and backtick</p>"
`;

