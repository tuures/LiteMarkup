      {
        "name": "",
        "txt": "</broken>",
      },
    ],
    "name": "p",
  },
  {
    "name": "htm",
    "raw": "<div>
  but this doesn't get split because the inner closing tag is indented
  <div>
  </div>

</div>",
  },
  {
    "name": "htm",
    "raw": "<broken>
garbage in </broken> garbage out
</broken>",
  },
  {
    "body": [
      {
        "name": "",
