{
  "name": "litemarkup",
  "version": "0.1.10",
  "description": "Unbloated Markdown-like markup language",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/litemarkup.d.ts",
      "default": "./dist/litemarkup.js"
    }
  },
  "bin": {
    "litemarkup": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "keywords": ["markdown", "markup", "parser", "html", "typescript", "simple", "lightweight"],
  "homepage": "https://tuures.github.io/LiteMarkup/",
  "repository": "github:tuures/LiteMarkup",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.10",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsdown": "^0.20.1",
    "typescript": "^5.9.3"
  }
}
